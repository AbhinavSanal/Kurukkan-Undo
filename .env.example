VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

VITE_MAPBOX_TOKEN=

# Optional campus defaults. These are set near CUSAT, Kochi.
VITE_CAMPUS_LAT=10.0469
VITE_CAMPUS_LNG=76.3188
VITE_CAMPUS_NAME=CUSAT Campus

# Keep reports fresh. The app clamps this to 20-30 minutes.
VITE_REPORT_TTL_MINUTES=25
VITE_REPORT_COOLDOWN_SECONDS=90
VITE_DUPLICATE_RADIUS_METERS=90
VITE_ZONE_ALERT_RADIUS_METERS=160

# Local Firebase emulator support.
VITE_USE_FIREBASE_EMULATORS=false
VITE_FIREBASE_FUNCTIONS_REGION=us-central1
